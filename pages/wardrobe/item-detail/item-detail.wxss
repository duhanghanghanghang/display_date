.container {
  padding: 24rpx;
  min-height: 100vh;
  background: #F8F4F7;
  box-sizing: border-box;
}

.image-wrap {
  width: 100%;
  height: 448rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.main-img {
  width: 100%;
  height: 100%;
}

.image-failed {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 28rpx;
}

.head-block {
  margin-bottom: 20rpx;
}

.item-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 12rpx;
}

.head-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.item-price {
  font-size: 36rpx;
  font-weight: 700;
  color: #D8A7B1;
}

.spacer {
  flex: 1;
}

.cat-pill {
  font-size: 22rpx;
  color: #333;
  background: #F0E8EB;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
}

.gray-block {
  font-size: 26rpx;
  color: #888;
  line-height: 1.7;
  margin-bottom: 32rpx;
}

.g-line {
  margin-bottom: 4rpx;
}

.btn-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 32rpx;
}

.b-primary,
.b-ghost {
  flex: 1;
  font-size: 28rpx;
  line-height: 1.2;
  padding: 24rpx 0;
  border-radius: 20rpx;
  border: none;
  margin: 0;
}

.b-primary {
  background: #D8A7B1;
  color: #fff;
}

.b-ghost {
  background: #F0E8EB;
  color: #333;
}

.b-primary::after,
.b-ghost::after {
  border: none;
}

.del-tap {
  text-align: center;
  color: #f87171;
  font-size: 26rpx;
  padding: 16rpx;
}

.empty-tip {
  text-align: center;
  color: #999;
  padding: 80rpx;
}
