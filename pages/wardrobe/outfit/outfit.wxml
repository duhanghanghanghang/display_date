<!-- pages/wardrobe/outfit/outfit.wxml -->
<view class="outfit-container">
  <view wx:if="{{loading}}" class="loading-tip">加载中...</view>
  <block wx:else>
  <navigator class="recommend-link" url="/pages/wardrobe/recommend/recommend" hover-class="none">
    <text>智能穿搭</text>
    <text class="r-arrow">›</text>
  </navigator>
  <!-- 搭配预览区：垂直拼接，可点击单张调整比例 -->
  <view class="avatar-section">
    <view class="preview-area" wx:if="{{selectedForPreview.length > 0}}">
      <view class="preview-slot" wx:for="{{selectedForPreview}}" wx:key="item.item.id"
            wx:if="{{item.item.imageUrl && !item.item._imgFailed}}"
            style="height: {{((itemHeights[item.item.id] || 200) * (itemScales[item.item.id] || 0.6))}}rpx"
            bindtap="onPreviewSlotTap" data-index="{{index}}" data-item="{{item}}">
        <image class="preview-slot-img" src="{{item.item.imageUrl}}" mode="widthFix"
               style="transform: scale({{itemScales[item.item.id] || 0.6}}); transform-origin: top center"
               bindload="onPreviewImageLoad" binderror="onPreviewImageError" data-id="{{item.item.id}}" />
      </view>
    </view>
    <view wx:else class="preview-empty">
      <text class="preview-empty-icon">👔</text>
      <text class="preview-empty-text">在下方选择衣服，搭配你的造型</text>
    </view>
    <view class="selection-count">已选择 {{selectedCount}} 件</view>
  </view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="action-btn clear" bindtap="clearSelection">清空</button>
    <button class="action-btn export" bindtap="exportOutfitImage">生成长图</button>
  </view>

  <!-- 分类选择区 -->
  <view class="categories-section">
  <view wx:if="{{categories.length === 0}}" class="empty-categories">
    <text>请先添加分类和衣服</text>
  </view>
  <scroll-view wx:else class="categories-scroll" scroll-y>
    <view class="category-block" wx:for="{{categories}}" wx:key="id" wx:for-item="category">
      <view class="category-header">
        <text class="category-name">{{category.name}}</text>
        <view class="category-header-right">
          <text class="category-count">{{category.itemCount}}件</text>
          <text wx:if="{{category.itemCount > 4}}" class="expand-btn" bindtap="toggleCategoryExpand" data-id="{{category.id}}">{{category.expanded ? '收起' : '展开'}}</text>
        </view>
      </view>
      
      <view class="items-row {{category.expanded ? 'expanded' : ''}}">
        <view class="item-chip" 
              wx:for="{{category.items}}" 
              wx:key="id"
              wx:for-item="item"
              class="{{selectedItems[category.id] === item.id ? 'selected' : ''}}"
              bindtap="selectItem"
              data-category-id="{{category.id}}"
              data-item-id="{{item.id}}">
          <image wx:if="{{item.imageUrl && !item._imgFailed}}" class="chip-image" src="{{item.imageUrl}}" mode="aspectFill" binderror="onChipImageError" data-category-id="{{category.id}}" data-item-id="{{item.id}}" />
          <view wx:else class="chip-placeholder">
            <text>{{item.placeholderText}}</text>
          </view>
          <text class="chip-name">{{item.name || '未命名'}}</text>
        </view>
      </view>
    </view>
  </scroll-view>
  </view>

  <!-- 已保存的搭配 -->
  <view class="saved-outfits-section" wx:if="{{savedOutfits.length > 0}}">
    <view class="section-title">我的搭配方案</view>
    <scroll-view class="outfits-scroll" scroll-x>
      <view class="outfit-card" wx:for="{{savedOutfits}}" wx:key="id" bindtap="loadOutfit" data-outfit="{{item}}">
        <view class="outfit-card-preview">
          <block wx:if="{{item.previewImages && item.previewImages.length > 0}}">
            <image wx:for="{{item.previewImages}}" wx:key="*this" wx:for-item="img" class="outfit-thumb" src="{{img}}" mode="aspectFill" />
          </block>
          <view wx:else class="outfit-thumb-placeholder">👔</view>
        </view>
        <text class="outfit-name">{{item.name}}</text>
        <text class="outfit-meta">{{item.itemCount}}件</text>
        <text class="outfit-edit" catchtap="showEditOutfit" data-outfit="{{item}}">编辑</text>
        <text class="delete-outfit" catchtap="deleteOutfit" data-id="{{item.id}}">✕</text>
      </view>
    </scroll-view>
  </view>
  <view class="empty-outfits" wx:elif="{{!loading && savedOutfits.length === 0}}">
    <text class="empty-outfits-text">保存你的第一套搭配吧</text>
  </view>

  <canvas type="2d" id="outfitPosterCanvas" class="poster-canvas"></canvas>
  </block>
</view>

<!-- 保存/编辑搭配弹窗 -->
<view class="modal-mask" wx:if="{{showSaveDialog}}" bindtap="closeSaveDialog">
  <view class="modal-content modal-content-large" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">{{editingOutfitId ? '编辑搭配' : '保存搭配'}}</text>
      <text class="modal-close" bindtap="closeSaveDialog">✕</text>
    </view>
    
    <scroll-view class="modal-body" scroll-y>
      <view class="form-item">
        <text class="label">搭配名称<text class="required">*</text></text>
        <input class="common-input" placeholder="如：上班通勤、周末休闲" value="{{outfitName}}" bindinput="onOutfitNameInput" maxlength="30" />
      </view>
      <view class="form-item">
        <text class="label">适用场合</text>
        <input class="common-input" placeholder="如：上班、休闲、约会" value="{{outfitOccasion}}" bindinput="onOutfitOccasionInput" />
      </view>
      <view class="form-item">
        <text class="label">适用季节</text>
        <input class="common-input" placeholder="如：春、夏、秋、冬" value="{{outfitSeason}}" bindinput="onOutfitSeasonInput" />
      </view>
    </scroll-view>
    
    <view class="modal-footer">
      <button class="modal-btn cancel" catchtap="closeSaveDialog">取消</button>
      <button class="modal-btn confirm" catchtap="saveOutfit">保存</button>
    </view>
  </view>
</view>

<!-- 比例调整弹窗 -->
<view class="modal-mask" wx:if="{{showScaleModal}}" bindtap="closeScaleModal">
  <view class="modal-content" catchtap="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">调整比例</text>
      <text class="modal-close" bindtap="closeScaleModal">✕</text>
    </view>
    <view class="modal-body">
      <text class="scale-label">{{editingScaleItem ? editingScaleItem.categoryName + ' ' + (editingScaleItem.item.name || '') : ''}}</text>
      <slider min="50" max="150" value="{{editingScaleValue * 100}}" step="5" show-value bindchange="onScaleSliderChange" />
      <text class="scale-hint">50%-150%，可调整该图片的显示比例</text>
    </view>
    <view class="modal-footer">
      <button class="modal-btn cancel" catchtap="closeScaleModal">取消</button>
      <button class="modal-btn confirm" catchtap="confirmScaleAdjust">确定</button>
    </view>
  </view>
</view>
