/**
 * 统一样式 - 基于微信设计规范
 * 所有页面弹窗、输入框、按钮使用此规范
 */

/* ========== 输入框（修复文字裁剪问题） ========== */
/* 微信小程序 input 需明确 height + padding 0 左右，避免文字被裁剪 */
.common-input,
.input-single {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  border: 2rpx solid var(--border-color, #e8e8e8);
  border-radius: var(--radius-md, 12rpx);
  font-size: 30rpx;
  line-height: 88rpx;
  background-color: #fff;
}

.common-input::placeholder {
  color: var(--text-tertiary, #999);
}

/* ========== 弹窗 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  max-width: 90%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-content.large {
  width: 90%;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 32rpx 24rpx;
  border-bottom: 1rpx solid var(--border-light, #f0f0f0);
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary, #333);
}

.modal-close {
  font-size: 40rpx;
  color: var(--text-tertiary, #999);
  padding: 8rpx;
  line-height: 1;
}

.modal-body {
  padding: 32rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid var(--border-light, #f0f0f0);
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  font-size: 30rpx;
  border: none;
  border-radius: 0;
  background: #fff;
}

.modal-btn.cancel {
  color: var(--text-secondary, #666);
  border-right: 1rpx solid var(--border-light, #f0f0f0);
}

.modal-btn.primary,
.modal-btn.confirm {
  color: var(--primary-color, #4A90E2);
  font-weight: 500;
}

/* ========== 表单 ========== */
.form-item {
  margin-bottom: 28rpx;
}

.form-item .label {
  display: block;
  font-size: 28rpx;
  color: var(--text-primary, #333);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.form-item .required {
  color: var(--error-color, #f5576c);
  margin-left: 4rpx;
}

.form-item .input,
.form-item .picker-view {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  box-sizing: border-box;
  background: var(--bg-page, #f5f5f5);
  border-radius: var(--radius-md, 12rpx);
  font-size: 30rpx;
  line-height: 88rpx;
  border: none;
}

.form-item .picker-view {
  display: flex;
  align-items: center;
}

.form-item .textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  background: var(--bg-page, #f5f5f5);
  border-radius: var(--radius-md, 12rpx);
  font-size: 30rpx;
  line-height: 1.5;
  border: none;
}
