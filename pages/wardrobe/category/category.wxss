.list {
  margin-bottom: 120rpx;
}

.cat-item {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.cat-main {
  flex: 1;
}

.cat-name {
  font-size: 32rpx;
  color: #333;
  display: block;
  margin-bottom: 8rpx;
}

.cat-count {
  font-size: 26rpx;
  color: #999;
}

.cat-actions {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 28rpx;
  color: var(--primary-color, #4A90E2);
}

.action-btn.danger {
  color: #e74c3c;
}

.add-btn {
  position: fixed;
  bottom: 48rpx;
  left: 24rpx;
  right: 24rpx;
  background: var(--primary-color, #4A90E2);
  color: #fff;
  text-align: center;
  padding: 28rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
}

/* 弹窗样式已由 styles/common.wxss 统一提供 */
