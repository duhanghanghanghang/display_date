<view class="wardrobe-page">
  <view class="top-bar">
    <text class="top-icon" bindtap="goToCategory" aria-label="分类">☰</text>
    <view class="top-spacer" />
    <text class="top-icon" bindtap="goToItemList" aria-label="搜索">🔍</text>
  </view>

  <view class="stats-row">
    <view class="stat-block">
      <text class="stat-label">总衣物</text>
      <text class="stat-num">{{statTotal}}</text>
    </view>
    <view class="stat-block">
      <text class="stat-label">分类</text>
      <text class="stat-num">{{statCategoryCount}}</text>
    </view>
    <view class="stat-block">
      <text class="stat-label">总价值</text>
      <text class="stat-num stat-price">¥{{statValueText}}</text>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">衣物分类</text>
      <text class="section-link" bindtap="goToCategory">管理分类</text>
    </view>
    <view class="cat-grid">
      <view
        class="cat-cell"
        wx:for="{{categoryCells}}"
        wx:key="key"
        bindtap="onCategoryCellTap"
        data-cell="{{item}}"
      >
        <text class="cat-emoji">{{item.emoji}}</text>
        <text class="cat-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <view class="section">
    <view class="section-head">
      <text class="section-title">全部衣物</text>
      <view class="add-inline" bindtap="goToAddItem">
        <text class="add-icon">+</text>
        <text>添加</text>
      </view>
    </view>
    <view class="item-grid" wx:if="{{homeItems.length > 0}}">
      <view class="item-card" wx:for="{{homeItems}}" wx:key="id" bindtap="goItemDetail" data-id="{{item.id}}">
        <image
          wx:if="{{item.imageUrl}}"
          class="item-img"
          src="{{item.imageUrl}}"
          mode="aspectFill"
        />
        <view wx:else class="item-img item-img-ph">无图</view>
        <view class="item-bottom">
          <text class="item-name ellipsis">{{item.name}}</text>
          <text class="item-price" wx:if="{{item.price != null && item.price !== ''}}">¥{{item.price}}</text>
        </view>
      </view>
    </view>
    <view class="empty-hint" wx:else>暂无衣物，点击添加录入第一件吧</view>
    <view
      class="more-link"
      wx:if="{{statTotal > homeItems.length}}"
      bindtap="goToItemList"
    >查看全部</view>
  </view>
</view>
