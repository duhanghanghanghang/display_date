.wardrobe-page {
  min-height: 100vh;
  background: #F8F4F7;
  padding: 0 24rpx 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.top-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0 8rpx;
}

.top-icon {
  font-size: 40rpx;
  color: #A88A93;
  padding: 8rpx 12rpx;
}

.top-spacer {
  flex: 1;
}

/* 统计 */
.stats-row {
  display: flex;
  justify-content: space-between;
  background: #F0E8EB;
  border-radius: 24rpx;
  padding: 32rpx 24rpx;
  margin-bottom: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
}

.stat-block {
  flex: 1;
  text-align: center;
}

.stat-label {
  display: block;
  font-size: 24rpx;
  color: #888888;
  margin-bottom: 8rpx;
}

.stat-num {
  font-size: 34rpx;
  font-weight: 600;
  color: #333333;
}

.stat-price {
  color: #D8A7B1;
}

/* 区块 */
.section {
  margin-bottom: 36rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.section-link {
  font-size: 24rpx;
  color: #D8A7B1;
}

.add-inline {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 24rpx;
  color: #D8A7B1;
}

.add-icon {
  font-size: 28rpx;
  font-weight: 600;
}

/* 分类四宫格 */
.cat-grid {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  gap: 16rpx;
}

.cat-cell {
  flex: 1;
  min-width: 0;
  background: #F0E8EB;
  border-radius: 16rpx;
  padding: 20rpx 8rpx;
  text-align: center;
  box-sizing: border-box;
}

.cat-emoji {
  display: block;
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.cat-name {
  font-size: 20rpx;
  color: #333333;
  line-height: 1.2;
  word-break: break-all;
}

/* 衣物双列 */
.item-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 0;
}

.item-card {
  width: 48.5%;
  background: #FFFFFF;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.item-img {
  width: 100%;
  height: 220rpx;
  background: #ECE6E8;
  display: block;
}

.item-img-ph {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: #999999;
}

.item-bottom {
  padding: 16rpx 16rpx 20rpx;
}

.item-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333333;
  margin-bottom: 6rpx;
}

.item-price {
  font-size: 22rpx;
  color: #D8A7B1;
}

.ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.empty-hint {
  text-align: center;
  color: #888888;
  font-size: 26rpx;
  padding: 48rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
}

.more-link {
  text-align: center;
  color: #D8A7B1;
  font-size: 26rpx;
  margin-top: 8rpx;
  padding: 16rpx;
}
