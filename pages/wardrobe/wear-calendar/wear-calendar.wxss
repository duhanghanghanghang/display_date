.calendar-page {
  padding: 24rpx;
  background: linear-gradient(180deg, #e8f4fc 0%, #f5f5f5 200rpx);
  min-height: 100vh;
}

.month-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 24rpx;
}

.month-btn {
  font-size: 48rpx;
  color: #4A90E2;
  padding: 0 20rpx;
}

.month-title {
  font-size: 34rpx;
  font-weight: 600;
}

.week-head {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  text-align: center;
  font-size: 24rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.day-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
  gap: 8rpx;
}

.day-cell {
  aspect-ratio: 1;
  background: #fff;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.day-cell.empty {
  background: transparent;
  box-shadow: none;
}

.day-cell.has-log {
  background: #e3f2fd;
}

.day-cell.today {
  border: 2rpx solid #4A90E2;
}

.day-num {
  font-size: 28rpx;
}

.dot {
  font-size: 36rpx;
  color: #4A90E2;
  line-height: 1;
}

.hint {
  text-align: center;
  font-size: 24rpx;
  color: #999;
  margin-top: 32rpx;
}

.modal-mask {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.modal-box {
  width: 620rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
}

.picker-line {
  padding: 20rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.modal-input {
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 24rpx;
  font-size: 28rpx;
}

.modal-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  justify-content: flex-end;
}

.modal-actions .btn {
  font-size: 26rpx;
  margin: 0;
}

.btn.ghost {
  background: #f0f0f0;
  color: #333;
}

.btn.primary {
  background: #4A90E2;
  color: #fff;
}

.btn.danger {
  background: #ffeeee;
  color: #c00;
}
