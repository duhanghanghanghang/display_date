<view class="mine-page">
  <view class="top-row">
    <view class="top-l" />
    <text class="cog" bindtap="goSettings" aria-label="设置">⚙</text>
  </view>
  <view class="user-block">
    <image class="avatar" src="/images/person-template.png" mode="aspectFill" />
    <view class="user-text">
      <text class="user-name">衣橱达人</text>
      <text class="user-desc">智能衣橱 · 记录美好生活</text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goStats">
      <view class="menu-left">
        <text class="menu-icon">▤</text>
        <text>衣橱统计</text>
      </view>
      <text class="menu-chevron">›</text>
    </view>
    <view class="menu-item" bindtap="goIdle">
      <view class="menu-left">
        <text class="menu-icon">⌫</text>
        <text>清理闲置</text>
      </view>
      <text class="menu-chevron">›</text>
    </view>
  </view>

  <button class="logout-btn" bindtap="onLogout">退出登录</button>
</view>
