.crop-container {
  min-height: 100vh;
  background: #1a1a1a;
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.crop-tip {
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
  margin-bottom: 24rpx;
}

.crop-preview-wrap {
  position: relative;
  width: 100%;
  max-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.crop-preview-img {
  width: 100%;
  max-height: 60vh;
}

.crop-frame {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 400rpx;
  height: 533rpx;
  border: 4rpx solid rgba(74, 144, 226, 0.8);
  box-sizing: border-box;
  pointer-events: none;
}

.crop-canvas {
  position: fixed;
  left: -9999px;
  width: 600px;
  height: 800px;
}

.crop-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  display: flex;
  gap: 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
}

.crop-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  border: none;
}

.crop-btn.cancel {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
}

.crop-btn.confirm {
  background: var(--primary-color, #4A90E2);
  color: #fff;
}
