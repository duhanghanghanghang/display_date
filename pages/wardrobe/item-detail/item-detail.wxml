<view class="container detail-proto" wx:if="{{!loading && item}}">
  <view class="image-wrap" wx:if="{{item.imageUrl && !item._imgFailed}}" bindtap="previewImage">
    <image class="main-img" src="{{item.imageUrl}}" mode="aspectFill" binderror="onImageError" />
  </view>
  <view class="image-wrap image-failed" wx:elif="{{item.imageUrl}}">
    <text>图片加载失败</text>
  </view>
  <view class="image-wrap image-failed" wx:else>
    <text>无图片</text>
  </view>

  <view class="head-block">
    <text class="item-name">{{item.name}}</text>
    <view class="head-row">
      <text class="item-price" wx:if="{{item.price != null && item.price !== ''}}">¥{{item.price}}</text>
      <view wx:else class="spacer" />
      <text class="cat-pill">{{item.categoryName || '未分类'}}</text>
    </view>
  </view>

  <view class="gray-block">
    <view class="g-line" wx:if="{{item.brand}}"><text>品牌：{{item.brand}}</text></view>
    <view class="g-line" wx:if="{{item.size}}"><text>尺码：{{item.size}}</text></view>
  </view>

  <view class="btn-row">
    <button class="b-primary" bindtap="goVirtual">虚拟试衣</button>
    <button class="b-ghost" bindtap="goEdit">编辑信息</button>
  </view>

  <view class="del-tap" bindtap="deleteItem">删除衣物</view>
</view>

<view class="empty-tip" wx:elif="{{loading}}">加载中...</view>
<view class="empty-tip" wx:else>加载失败</view>
