.stats-page {
  min-height: 100vh;
  background: #F8F4F7;
  padding: 24rpx;
  box-sizing: border-box;
}

.chart-ph {
  background: #F0E8EB;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  color: #888;
  font-size: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.chart-ph.line {
  min-height: 200rpx;
}

.chart-ico {
  margin-right: 8rpx;
  color: #D8A7B1;
}

.bar-list {
  margin-top: 8rpx;
}

.bar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
  font-size: 22rpx;
  color: #333;
}

.bar-name {
  width: 100rpx;
  flex-shrink: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bar-track {
  flex: 1;
  height: 16rpx;
  background: #fff;
  border-radius: 8rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  background: #D8A7B1;
  border-radius: 8rpx;
  min-width: 0;
}

.bar-pct {
  width: 72rpx;
  text-align: right;
  color: #A88A93;
  flex-shrink: 0;
}

.month-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.month-item {
  width: 30%;
  background: #fff;
  border-radius: 12rpx;
  padding: 12rpx;
  box-sizing: border-box;
  text-align: center;
}

.m-label {
  display: block;
  font-size: 20rpx;
  color: #888;
}

.m-val {
  display: block;
  font-size: 24rpx;
  color: #333;
  font-weight: 600;
  margin-top: 4rpx;
}

.kpi-row {
  display: flex;
  gap: 20rpx;
}

.kpi {
  flex: 1;
  background: #F0E8EB;
  border-radius: 20rpx;
  padding: 24rpx;
  text-align: center;
}

.kpi-label {
  display: block;
  font-size: 22rpx;
  color: #888;
}

.kpi-val {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #333;
  margin: 8rpx 0;
}

.kpi-hint {
  font-size: 20rpx;
  color: #aaa;
}

.loading {
  text-align: center;
  padding: 100rpx;
  color: #999;
}
