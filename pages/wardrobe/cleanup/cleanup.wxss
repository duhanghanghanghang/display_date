.cleanup {
  min-height: 100vh;
  background: #F8F4F7;
  padding: 24rpx;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

.tip {
  background: #F0E8EB;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  font-size: 24rpx;
  color: #333;
  margin-bottom: 24rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.row {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.checkbox {
  width: 36rpx;
  height: 36rpx;
  border: 2rpx solid #ccc;
  border-radius: 8rpx;
  flex-shrink: 0;
}

.checkbox.on {
  background: #D8A7B1;
  border-color: #D8A7B1;
}

.thumb {
  width: 96rpx;
  height: 96rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  background: #eee;
}

.row-mid {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.n {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.d {
  font-size: 22rpx;
  color: #888;
}

.p {
  font-size: 26rpx;
  color: #D8A7B1;
  flex-shrink: 0;
}

.empty {
  text-align: center;
  color: #999;
  padding: 60rpx 20rpx;
  font-size: 26rpx;
}

.del {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #f87171;
  color: #fff;
  border-radius: 20rpx;
  font-size: 28rpx;
}

.del[disabled] {
  opacity: 0.5;
  color: #fff;
}
