.filter-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 24rpx;
  padding: 16rpx 0;
}

.filter-item {
  background: #fff;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  color: #666;
}

.filter-item.reset {
  color: #4A90E2;
}

.list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.list .item-card {
  width: calc((100% - 20rpx) / 2);
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}

.item-img {
  width: 100%;
  height: 280rpx;
  display: block;
  background: #f0f0f0;
}

.item-name {
  display: block;
  padding: 12rpx;
  font-size: 26rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-meta {
  display: block;
  padding: 0 12rpx 12rpx;
  font-size: 22rpx;
  color: #999;
}

.load-more {
  text-align: center;
  padding: 32rpx;
  font-size: 26rpx;
  color: #999;
}
