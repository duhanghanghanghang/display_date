/* pages/wardrobe/outfit/outfit.wxss */
.outfit-container {
  min-height: 100vh;
  background: linear-gradient(135deg, #a8edea 0%, #fed6e3 100%);
  padding: 30rpx;
  display: flex;
  flex-direction: column;
}

/* 加载 */
.loading-tip {
  text-align: center;
  padding: 80rpx;
  color: #999;
  font-size: 28rpx;
}

/* 搭配预览区 */
.avatar-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.preview-area {
  min-height: 200rpx;
}

.preview-items {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  justify-content: center;
}

.preview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
}

.preview-label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 8rpx;
}

.preview-img,
.preview-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
}

.preview-img {
  border: 2rpx solid #eee;
}

.preview-placeholder {
  background: linear-gradient(135deg, var(--primary-color, #4A90E2) 0%, #3A7BC8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

.preview-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 0;
}

.preview-empty-icon {
  font-size: 80rpx;
  opacity: 0.5;
  margin-bottom: 16rpx;
}

.preview-empty-text {
  font-size: 26rpx;
  color: #999;
}

.selection-count {
  margin-top: 20rpx;
  font-size: 26rpx;
  color: #666;
  text-align: center;
}

/* 操作按钮 */
.action-bar {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.action-btn.clear {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
}

.action-btn.save {
  background: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
  color: #fff;
}

/* 分类选择区 */
.categories-section {
  flex: 1;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}

.categories-scroll {
  max-height: 500rpx;
}

.empty-categories {
  padding: 60rpx;
  text-align: center;
  color: #999;
  font-size: 28rpx;
}

.category-block {
  margin-bottom: 40rpx;
}

.category-block:last-child {
  margin-bottom: 0;
}

.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.category-name {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
}

.category-count {
  font-size: 24rpx;
  color: #999;
}

.category-header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.expand-btn {
  font-size: 24rpx;
  color: var(--primary-color, #4A90E2);
}

.items-row {
  display: flex;
  flex-wrap: nowrap;
  overflow-x: hidden;
  gap: 24rpx;
  padding-bottom: 8rpx;
}

.items-row.expanded {
  overflow-x: auto;
}

.item-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 140rpx;
  min-width: 140rpx;
  flex-shrink: 0;
  text-align: center;
}

.item-chip.selected {
  transform: scale(1.1);
  transition: transform 0.3s;
}

.chip-image,
.chip-placeholder {
  width: 120rpx;
  height: 120rpx;
  min-height: 120rpx;
  border-radius: 12rpx;
  margin: 0 auto 8rpx;
  display: block;
}

.chip-image {
  border: 4rpx solid transparent;
  background: #f0f0f0;
}

.item-chip.selected .chip-image {
  border-color: #667eea;
  box-shadow: 0 0 20rpx rgba(102, 126, 234, 0.5);
}

.chip-placeholder {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 36rpx;
  font-weight: bold;
  border: 4rpx solid transparent;
}

.item-chip.selected .chip-placeholder {
  border-color: #f5576c;
  box-shadow: 0 0 20rpx rgba(245, 87, 108, 0.5);
}

.chip-name {
  font-size: 24rpx;
  color: #666;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

/* 已保存的搭配 */
.saved-outfits-section {
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 20rpx;
}

.outfits-scroll {
  white-space: nowrap;
  height: 200rpx;
}

.modal-content-large {
  width: 90%;
  max-height: 70vh;
}

.outfit-card {
  position: relative;
  display: inline-block;
  width: 360rpx;
  min-height: 180rpx;
  background: #fff;
  border: 2rpx solid #eee;
  border-radius: 16rpx;
  margin-right: 20rpx;
  padding: 16rpx;
  vertical-align: top;
}

.outfit-card-preview {
  width: 100%;
  height: 100rpx;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
  background: #f5f5f5;
  display: flex;
  flex-direction: row;
}

.outfit-thumb {
  flex: 1;
  width: 0;
  height: 100%;
  min-width: 0;
}

.outfit-thumb-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.outfit-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.outfit-meta {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.outfit-edit {
  position: absolute;
  bottom: 12rpx;
  left: 16rpx;
  font-size: 22rpx;
  color: var(--primary-color, #4A90E2);
}

.delete-outfit {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 50%;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.empty-outfits {
  padding: 40rpx;
  text-align: center;
}

.empty-outfits-text {
  font-size: 28rpx;
  color: #999;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  width: 80%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 40rpx 30rpx 20rpx;
  border-bottom: 1rpx solid #eee;
}

.modal-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  font-size: 48rpx;
  color: #999;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-body {
  padding: 40rpx 30rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #eee;
}

.modal-btn {
  flex: 1;
  height: 100rpx;
  line-height: 100rpx;
  text-align: center;
  font-size: 32rpx;
  border: none;
  border-radius: 0;
  background: #fff;
}

.modal-btn.cancel {
  color: #999;
  border-right: 1rpx solid #eee;
}

.modal-btn.confirm {
  color: var(--primary-color, #4A90E2);
  font-weight: 500;
}
